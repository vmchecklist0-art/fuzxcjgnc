# Neon database connection
# Get your Neon database URL from the Neon dashboard and set it here.
NEON_DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<database>

# ImgBB upload key for secure image uploads from the app
# Create a free account at https://imgbb.com and generate a key.
IMGBB_API_KEY=your_imgbb_api_key
